<span class="k">def</span> <span class="nf">generate_ar_stock_pdf_report</span><span class="p">(</span>
    <span class="n">data</span><span class="o">=</span><span class="kc">None</span><span class="p">,</span>
    <span class="n">ticker</span><span class="o">=</span><span class="kc">None</span><span class="p">,</span>
    <span class="n">x_series</span><span class="o">=</span><span class="kc">None</span><span class="p">,</span>
    <span class="n">output_pdf_path</span><span class="o">=</span><span class="kc">None</span><span class="p">,</span>
    <span class="n">price_column</span><span class="o">=</span><span class="s2">"Close"</span><span class="p">,</span>
    <span class="n">max_lag</span><span class="o">=</span><span class="mi">30</span><span class="p">,</span>
    <span class="n">pacf_buffer</span><span class="o">=</span><span class="mi">5</span><span class="p">,</span>
    <span class="n">train_ratio_candidates</span><span class="o">=</span><span class="p">(</span><span class="mf">0.50</span><span class="p">,</span> <span class="mf">0.60</span><span class="p">,</span> <span class="mf">0.70</span><span class="p">,</span> <span class="mf">0.80</span><span class="p">),</span>
    <span class="n">selection_rule</span><span class="o">=</span><span class="s2">"bic_then_validation_r2"</span><span class="p">,</span>
    <span class="n">bootstrap_B</span><span class="o">=</span><span class="mi">5000</span><span class="p">,</span>
    <span class="n">bootstrap_seed</span><span class="o">=</span><span class="mi">42</span><span class="p">,</span>
    <span class="n">alpha</span><span class="o">=</span><span class="mf">0.05</span><span class="p">,</span>
    <span class="n">flags</span><span class="o">=</span><span class="kc">None</span><span class="p">,</span>
<span class="p">):</span>
<span class="w">    </span><span class="sd">"""</span>
<span class="sd">    Generate an AR stock analysis PDF report up to stationarity.</span>

<span class="sd">    Inputs</span>
<span class="sd">    ------</span>
<span class="sd">    data:</span>
<span class="sd">        Usually a yfinance-style DataFrame.</span>
<span class="sd">        Supports:</span>
<span class="sd">            data[price_column][ticker]</span>
<span class="sd">        or:</span>
<span class="sd">            data[ticker]</span>
<span class="sd">        depending on shape.</span>
<span class="sd">    ticker:</span>
<span class="sd">        Stock ticker string.</span>
<span class="sd">    x_series:</span>
<span class="sd">        Optional pd.Series. If provided, it overrides data/ticker extraction.</span>
<span class="sd">    output_pdf_path:</span>
<span class="sd">        Path for output PDF.</span>
<span class="sd">    flags:</span>
<span class="sd">        Dict controlling sections/figures.</span>

<span class="sd">    Default flags:</span>
<span class="sd">        include_price_plot</span>
<span class="sd">        include_selection_tables</span>
<span class="sd">        include_pacf_plot</span>
<span class="sd">        include_aic_bic_plot</span>
<span class="sd">        include_validation_plot</span>
<span class="sd">        include_inference</span>
<span class="sd">        include_covariance_matrix</span>
<span class="sd">        include_stationarity</span>
<span class="sd">    """</span>

    <span class="n">default_flags</span> <span class="o">=</span> <span class="p">{</span>
        <span class="s2">"include_price_plot"</span><span class="p">:</span> <span class="kc">True</span><span class="p">,</span>
        <span class="s2">"include_selection_tables"</span><span class="p">:</span> <span class="kc">True</span><span class="p">,</span>
        <span class="s2">"include_pacf_plot"</span><span class="p">:</span> <span class="kc">True</span><span class="p">,</span>
        <span class="s2">"include_aic_bic_plot"</span><span class="p">:</span> <span class="kc">True</span><span class="p">,</span>
        <span class="s2">"include_validation_plot"</span><span class="p">:</span> <span class="kc">True</span><span class="p">,</span>
        <span class="s2">"include_inference"</span><span class="p">:</span> <span class="kc">True</span><span class="p">,</span>
        <span class="s2">"include_covariance_matrix"</span><span class="p">:</span> <span class="kc">True</span><span class="p">,</span>
        <span class="s2">"include_stationarity"</span><span class="p">:</span> <span class="kc">True</span><span class="p">,</span>
    <span class="p">}</span>

    <span class="k">if</span> <span class="n">flags</span> <span class="ow">is</span> <span class="kc">None</span><span class="p">:</span>
        <span class="n">flags</span> <span class="o">=</span> <span class="n">default_flags</span>
    <span class="k">else</span><span class="p">:</span>
        <span class="n">temp</span> <span class="o">=</span> <span class="n">default_flags</span><span class="o">.</span><span class="n">copy</span><span class="p">()</span>
        <span class="n">temp</span><span class="o">.</span><span class="n">update</span><span class="p">(</span><span class="n">flags</span><span class="p">)</span>
        <span class="n">flags</span> <span class="o">=</span> <span class="n">temp</span>

    <span class="k">if</span> <span class="n">x_series</span> <span class="ow">is</span> <span class="kc">None</span><span class="p">:</span>
        <span class="k">if</span> <span class="n">data</span> <span class="ow">is</span> <span class="kc">None</span> <span class="ow">or</span> <span class="n">ticker</span> <span class="ow">is</span> <span class="kc">None</span><span class="p">:</span>
            <span class="k">raise</span> <span class="ne">ValueError</span><span class="p">(</span><span class="s2">"Provide either x_series or both data and ticker."</span><span class="p">)</span>

        <span class="c1"># Try common yfinance-style shapes</span>
        <span class="k">try</span><span class="p">:</span>
            <span class="n">x_series</span> <span class="o">=</span> <span class="n">pd</span><span class="o">.</span><span class="n">Series</span><span class="p">(</span><span class="n">data</span><span class="p">[</span><span class="n">price_column</span><span class="p">][</span><span class="n">ticker</span><span class="p">])</span><span class="o">.</span><span class="n">dropna</span><span class="p">()</span>
        <span class="k">except</span> <span class="ne">Exception</span><span class="p">:</span>
            <span class="k">try</span><span class="p">:</span>
                <span class="n">x_series</span> <span class="o">=</span> <span class="n">pd</span><span class="o">.</span><span class="n">Series</span><span class="p">(</span><span class="n">data</span><span class="p">[</span><span class="n">ticker</span><span class="p">])</span><span class="o">.</span><span class="n">dropna</span><span class="p">()</span>
            <span class="k">except</span> <span class="ne">Exception</span> <span class="k">as</span> <span class="n">exc</span><span class="p">:</span>
                <span class="k">raise</span> <span class="ne">ValueError</span><span class="p">(</span>
                    <span class="s2">"Could not extract series. Pass x_series directly."</span>
                <span class="p">)</span> <span class="kn">from</span> <span class="nn">exc</span>
