<div class=" highlight hl-ipython3"><pre><span></span><span class="kn">import</span> <span class="nn">numpy</span> <span class="k">as</span> <span class="nn">np</span>
<span class="kn">import</span> <span class="nn">pandas</span> <span class="k">as</span> <span class="nn">pd</span>
<span class="kn">from</span> <span class="nn">scipy.stats</span> <span class="kn">import</span> <span class="n">t</span>

<span class="c1"># --------------------------------------------------</span>
<span class="c1"># 4.1 Normality assumption + coefficient distribution</span>
<span class="c1"># --------------------------------------------------</span>
<span class="c1"># Assumption:</span>
<span class="c1">#     epsilon ~ N(0, sigma^2 I)</span>
<span class="c1">#</span>
<span class="c1"># Then:</span>
<span class="c1">#     a_hat ~ N(a, sigma^2 (X^T X)^(-1))</span>

<span class="n">X</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">asarray</span><span class="p">(</span><span class="n">X_train</span><span class="p">)</span>
<span class="n">y</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">asarray</span><span class="p">(</span><span class="n">x_train_slice</span><span class="p">)</span><span class="o">.</span><span class="n">ravel</span><span class="p">()</span>
<span class="n">a_hat</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">asarray</span><span class="p">(</span><span class="n">a_hat</span><span class="p">)</span><span class="o">.</span><span class="n">ravel</span><span class="p">()</span>

<span class="n">n</span> <span class="o">=</span> <span class="nb">len</span><span class="p">(</span><span class="n">y</span><span class="p">)</span>
<span class="n">p</span> <span class="o">=</span> <span class="n">X</span><span class="o">.</span><span class="n">shape</span><span class="p">[</span><span class="mi">1</span><span class="p">]</span>

<span class="n">coef_names</span> <span class="o">=</span> <span class="p">[</span><span class="s2">"a_0"</span><span class="p">]</span> <span class="o">+</span> <span class="p">[</span><span class="sa">f</span><span class="s2">"a_</span><span class="si">{</span><span class="n">i</span><span class="si">}</span><span class="s2">"</span> <span class="k">for</span> <span class="n">i</span> <span class="ow">in</span> <span class="nb">range</span><span class="p">(</span><span class="mi">1</span><span class="p">,</span> <span class="n">p</span><span class="p">)]</span>

<span class="c1"># Fitted values and residuals</span>
<span class="n">y_hat</span> <span class="o">=</span> <span class="n">X</span> <span class="o">@</span> <span class="n">a_hat</span>
<span class="n">epsilon_hat</span> <span class="o">=</span> <span class="n">y</span> <span class="o">-</span> <span class="n">y_hat</span>

<span class="c1"># --------------------------------------------------</span>
<span class="c1"># 4.2 Variance estimation</span>
<span class="c1"># --------------------------------------------------</span>
<span class="c1"># sigma_hat^2 = RSS / (n - p)</span>

<span class="n">RSS</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">dot</span><span class="p">(</span><span class="n">epsilon_hat</span><span class="p">,</span> <span class="n">epsilon_hat</span><span class="p">)</span>
<span class="n">sigma2_hat</span> <span class="o">=</span> <span class="n">RSS</span> <span class="o">/</span> <span class="p">(</span><span class="n">n</span> <span class="o">-</span> <span class="n">p</span><span class="p">)</span>
<span class="n">sigma_hat</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">sqrt</span><span class="p">(</span><span class="n">sigma2_hat</span><span class="p">)</span>

<span class="n">XtX_inv</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">linalg</span><span class="o">.</span><span class="n">inv</span><span class="p">(</span><span class="n">X</span><span class="o">.</span><span class="n">T</span> <span class="o">@</span> <span class="n">X</span><span class="p">)</span>

<span class="c1"># Estimated covariance matrix of a_hat</span>
<span class="n">cov_a_hat</span> <span class="o">=</span> <span class="n">sigma2_hat</span> <span class="o">*</span> <span class="n">XtX_inv</span>

<span class="n">cov_a_hat_df</span> <span class="o">=</span> <span class="n">pd</span><span class="o">.</span><span class="n">DataFrame</span><span class="p">(</span>
    <span class="n">cov_a_hat</span><span class="p">,</span>
    <span class="n">index</span><span class="o">=</span><span class="n">coef_names</span><span class="p">,</span>
    <span class="n">columns</span><span class="o">=</span><span class="n">coef_names</span>
<span class="p">)</span>

<span class="nb">print</span><span class="p">(</span><span class="s2">"Estimated sigma^2:"</span><span class="p">,</span> <span class="n">sigma2_hat</span><span class="p">)</span>
<span class="nb">print</span><span class="p">(</span><span class="s2">"Estimated sigma:"</span><span class="p">,</span> <span class="n">sigma_hat</span><span class="p">)</span>
<span class="nb">print</span><span class="p">(</span><span class="s2">"Estimated covariance matrix of a_hat:"</span><span class="p">)</span>
<span class="n">display</span><span class="p">(</span><span class="n">cov_a_hat_df</span><span class="p">)</span>

<span class="c1"># --------------------------------------------------</span>
<span class="c1"># 4.3 Confidence intervals for coefficients</span>
<span class="c1"># --------------------------------------------------</span>

<span class="n">ALPHA</span> <span class="o">=</span> <span class="mf">0.05</span>
<span class="n">df</span> <span class="o">=</span> <span class="n">n</span> <span class="o">-</span> <span class="n">p</span>

<span class="n">t_crit</span> <span class="o">=</span> <span class="n">t</span><span class="o">.</span><span class="n">ppf</span><span class="p">(</span><span class="mi">1</span> <span class="o">-</span> <span class="n">ALPHA</span> <span class="o">/</span> <span class="mi">2</span><span class="p">,</span> <span class="n">df</span><span class="o">=</span><span class="n">df</span><span class="p">)</span>

<span class="n">coef_se</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">sqrt</span><span class="p">(</span><span class="n">np</span><span class="o">.</span><span class="n">diag</span><span class="p">(</span><span class="n">cov_a_hat</span><span class="p">))</span>

<span class="n">coef_lower</span> <span class="o">=</span> <span class="n">a_hat</span> <span class="o">-</span> <span class="n">t_crit</span> <span class="o">*</span> <span class="n">coef_se</span>
<span class="n">coef_upper</span> <span class="o">=</span> <span class="n">a_hat</span> <span class="o">+</span> <span class="n">t_crit</span> <span class="o">*</span> <span class="n">coef_se</span>

<span class="n">coef_ci_df</span> <span class="o">=</span> <span class="n">pd</span><span class="o">.</span><span class="n">DataFrame</span><span class="p">({</span>
    <span class="s2">"Coefficient"</span><span class="p">:</span> <span class="n">coef_names</span><span class="p">,</span>
    <span class="s2">"Estimate"</span><span class="p">:</span> <span class="n">a_hat</span><span class="p">,</span>
    <span class="s2">"Std_Error"</span><span class="p">:</span> <span class="n">coef_se</span><span class="p">,</span>
    <span class="s2">"CI_Lower"</span><span class="p">:</span> <span class="n">coef_lower</span><span class="p">,</span>
