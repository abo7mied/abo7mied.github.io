                <span class="sa">f</span><span class="s2">"</span><span class="si">{</span><span class="n">stationarity</span><span class="p">[</span><span class="s1">'bootstrap_stationarity_proportion'</span><span class="p">]</span><span class="si">:</span><span class="s2">.4f</span><span class="si">}</span><span class="s2">"</span><span class="p">,</span>
                <span class="n">styles</span><span class="p">[</span><span class="s2">"BodyText"</span><span class="p">]</span>
            <span class="p">))</span>

            <span class="k">if</span> <span class="n">stationarity</span><span class="p">[</span><span class="s2">"bootstrap_stationarity_proportion"</span><span class="p">]</span> <span class="o">&gt;=</span> <span class="mi">1</span> <span class="o">-</span> <span class="n">alpha</span><span class="p">:</span>
