<span class="c1"># ============================================================</span>

<span class="k">def</span> <span class="nf">compute_ar_inference</span><span class="p">(</span><span class="n">x_train</span><span class="p">,</span> <span class="n">p</span><span class="p">,</span> <span class="n">alpha</span><span class="o">=</span><span class="mf">0.05</span><span class="p">):</span>
<span class="w">    </span><span class="sd">"""</span>
<span class="sd">    Compute coefficient covariance, standard errors, and confidence intervals.</span>
<span class="sd">    """</span>
    <span class="n">fit</span> <span class="o">=</span> <span class="n">fit_ar_ols</span><span class="p">(</span><span class="n">x_train</span><span class="p">,</span> <span class="n">p</span><span class="p">)</span>

    <span class="n">X</span> <span class="o">=</span> <span class="n">fit</span><span class="p">[</span><span class="s2">"X_train"</span><span class="p">]</span>
    <span class="n">y</span> <span class="o">=</span> <span class="n">fit</span><span class="p">[</span><span class="s2">"y_train"</span><span class="p">]</span>
    <span class="n">a_hat</span> <span class="o">=</span> <span class="n">fit</span><span class="p">[</span><span class="s2">"a_hat"</span><span class="p">]</span>
    <span class="n">residuals</span> <span class="o">=</span> <span class="n">fit</span><span class="p">[</span><span class="s2">"residuals"</span><span class="p">]</span>

    <span class="n">n</span> <span class="o">=</span> <span class="nb">len</span><span class="p">(</span><span class="n">y</span><span class="p">)</span>
    <span class="n">k</span> <span class="o">=</span> <span class="n">X</span><span class="o">.</span><span class="n">shape</span><span class="p">[</span><span class="mi">1</span><span class="p">]</span>
    <span class="n">df</span> <span class="o">=</span> <span class="n">n</span> <span class="o">-</span> <span class="n">k</span>

    <span class="n">RSS</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">dot</span><span class="p">(</span><span class="n">residuals</span><span class="p">,</span> <span class="n">residuals</span><span class="p">)</span>
    <span class="n">sigma2_hat</span> <span class="o">=</span> <span class="n">RSS</span> <span class="o">/</span> <span class="n">df</span>
    <span class="n">sigma_hat</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">sqrt</span><span class="p">(</span><span class="n">sigma2_hat</span><span class="p">)</span>

    <span class="n">XtX_inv</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">linalg</span><span class="o">.</span><span class="n">pinv</span><span class="p">(</span><span class="n">X</span><span class="o">.</span><span class="n">T</span> <span class="o">@</span> <span class="n">X</span><span class="p">)</span>
    <span class="n">cov_a_hat</span> <span class="o">=</span> <span class="n">sigma2_hat</span> <span class="o">*</span> <span class="n">XtX_inv</span>

    <span class="n">t_crit</span> <span class="o">=</span> <span class="n">t</span><span class="o">.</span><span class="n">ppf</span><span class="p">(</span><span class="mi">1</span> <span class="o">-</span> <span class="n">alpha</span> <span class="o">/</span> <span class="mi">2</span><span class="p">,</span> <span class="n">df</span><span class="o">=</span><span class="n">df</span><span class="p">)</span>

    <span class="n">coef_names</span> <span class="o">=</span> <span class="p">[</span><span class="s2">"a_0"</span><span class="p">]</span> <span class="o">+</span> <span class="p">[</span><span class="sa">f</span><span class="s2">"a_</span><span class="si">{</span><span class="n">i</span><span class="si">}</span><span class="s2">"</span> <span class="k">for</span> <span class="n">i</span> <span class="ow">in</span> <span class="nb">range</span><span class="p">(</span><span class="mi">1</span><span class="p">,</span> <span class="n">k</span><span class="p">)]</span>
    <span class="n">coef_se</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">sqrt</span><span class="p">(</span><span class="n">np</span><span class="o">.</span><span class="n">diag</span><span class="p">(</span><span class="n">cov_a_hat</span><span class="p">))</span>

    <span class="n">coef_ci_df</span> <span class="o">=</span> <span class="n">pd</span><span class="o">.</span><span class="n">DataFrame</span><span class="p">({</span>
        <span class="s2">"Coefficient"</span><span class="p">:</span> <span class="n">coef_names</span><span class="p">,</span>
        <span class="s2">"Estimate"</span><span class="p">:</span> <span class="n">a_hat</span><span class="p">,</span>
        <span class="s2">"Std_Error"</span><span class="p">:</span> <span class="n">coef_se</span><span class="p">,</span>
        <span class="s2">"CI_Lower"</span><span class="p">:</span> <span class="n">a_hat</span> <span class="o">-</span> <span class="n">t_crit</span> <span class="o">*</span> <span class="n">coef_se</span><span class="p">,</span>
        <span class="s2">"CI_Upper"</span><span class="p">:</span> <span class="n">a_hat</span> <span class="o">+</span> <span class="n">t_crit</span> <span class="o">*</span> <span class="n">coef_se</span><span class="p">,</span>
    <span class="p">})</span>

    <span class="n">cov_df</span> <span class="o">=</span> <span class="n">pd</span><span class="o">.</span><span class="n">DataFrame</span><span class="p">(</span>
        <span class="n">cov_a_hat</span><span class="p">,</span>
        <span class="n">index</span><span class="o">=</span><span class="n">coef_names</span><span class="p">,</span>
        <span class="n">columns</span><span class="o">=</span><span class="n">coef_names</span>
    <span class="p">)</span>

    <span class="k">return</span> <span class="p">{</span>
        <span class="o">**</span><span class="n">fit</span><span class="p">,</span>
        <span class="s2">"n"</span><span class="p">:</span> <span class="n">n</span><span class="p">,</span>
        <span class="s2">"p"</span><span class="p">:</span> <span class="n">k</span><span class="p">,</span>
        <span class="s2">"df"</span><span class="p">:</span> <span class="n">df</span><span class="p">,</span>
        <span class="s2">"RSS"</span><span class="p">:</span> <span class="n">RSS</span><span class="p">,</span>
        <span class="s2">"sigma2_hat"</span><span class="p">:</span> <span class="n">sigma2_hat</span><span class="p">,</span>
        <span class="s2">"sigma_hat"</span><span class="p">:</span> <span class="n">sigma_hat</span><span class="p">,</span>
        <span class="s2">"XtX_inv"</span><span class="p">:</span> <span class="n">XtX_inv</span><span class="p">,</span>
        <span class="s2">"cov_a_hat"</span><span class="p">:</span> <span class="n">cov_a_hat</span><span class="p">,</span>
        <span class="s2">"cov_df"</span><span class="p">:</span> <span class="n">cov_df</span><span class="p">,</span>
        <span class="s2">"t_crit"</span><span class="p">:</span> <span class="n">t_crit</span><span class="p">,</span>
        <span class="s2">"coef_ci_df"</span><span class="p">:</span> <span class="n">coef_ci_df</span><span class="p">,</span>
    <span class="p">}</span>


<span class="c1"># ============================================================</span>
<span class="c1"># Stationarity</span>
<span class="c1"># ============================================================</span>

<span class="k">def</span> <span class="nf">ar_roots</span><span class="p">(</span><span class="n">coeffs</span><span class="p">):</span>
<span class="w">    </span><span class="sd">"""</span>
<span class="sd">    For constant-mean AR(p), coeffs are lag coefficients only:</span>
<span class="sd">        x_t = a_0 + a_1 x_{t-1} + ... + a_p x_{t-p} + epsilon_t</span>

<span class="sd">    Stationarity requires roots of</span>
<span class="sd">        1 - a_1 z - ... - a_p z^p = 0</span>
<span class="sd">    to satisfy |z| &gt; 1.</span>
<span class="sd">    """</span>
    <span class="n">coeffs</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">asarray</span><span class="p">(</span><span class="n">coeffs</span><span class="p">)</span><span class="o">.</span><span class="n">ravel</span><span class="p">()</span>
    <span class="n">poly_coeffs</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">concatenate</span><span class="p">((</span><span class="o">-</span><span class="n">coeffs</span><span class="p">[::</span><span class="o">-</span><span class="mi">1</span><span class="p">],</span> <span class="n">np</span><span class="o">.</span><span class="n">array</span><span class="p">([</span><span class="mf">1.0</span><span class="p">])))</span>
    <span class="n">roots</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">roots</span><span class="p">(</span><span class="n">poly_coeffs</span><span class="p">)</span>
    <span class="k">return</span> <span class="n">roots</span>


<span class="k">def</span> <span class="nf">is_stationary_ar</span><span class="p">(</span><span class="n">coeffs</span><span class="p">):</span>
    <span class="n">roots</span> <span class="o">=</span> <span class="n">ar_roots</span><span class="p">(</span><span class="n">coeffs</span><span class="p">)</span>
    <span class="k">return</span> <span class="nb">bool</span><span class="p">(</span><span class="n">np</span><span class="o">.</span><span class="n">all</span><span class="p">(</span><span class="n">np</span><span class="o">.</span><span class="n">abs</span><span class="p">(</span><span class="n">roots</span><span class="p">)</span> <span class="o">&gt;</span> <span class="mi">1</span><span class="p">)),</span> <span class="n">roots</span>


<span class="k">def</span> <span class="nf">bootstrap_stationarity</span><span class="p">(</span>
    <span class="n">a_hat</span><span class="p">,</span>
    <span class="n">cov_a_hat</span><span class="p">,</span>
    <span class="n">B</span><span class="o">=</span><span class="mi">5000</span><span class="p">,</span>
    <span class="n">seed</span><span class="o">=</span><span class="mi">42</span><span class="p">,</span>
    <span class="n">include_intercept</span><span class="o">=</span><span class="kc">True</span><span class="p">,</span>
<span class="p">):</span>
<span class="w">    </span><span class="sd">"""</span>
<span class="sd">    Bootstrap coefficient uncertainty using asymptotic normal approximation:</span>
<span class="sd">        a_boot ~ N(a_hat, cov_a_hat)</span>

<span class="sd">    Stationarity is computed from AR lag coefficients only.</span>
<span class="sd">    """</span>
    <span class="n">rng</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">random</span><span class="o">.</span><span class="n">default_rng</span><span class="p">(</span><span class="n">seed</span><span class="p">)</span>

    <span class="n">a_hat</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">asarray</span><span class="p">(</span><span class="n">a_hat</span><span class="p">)</span><span class="o">.</span><span class="n">ravel</span><span class="p">()</span>
    <span class="n">cov_a_hat</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">asarray</span><span class="p">(</span><span class="n">cov_a_hat</span><span class="p">)</span>

    <span class="k">if</span> <span class="n">include_intercept</span><span class="p">:</span>
        <span class="n">a_hat_stationarity</span> <span class="o">=</span> <span class="n">a_hat</span><span class="p">[</span><span class="mi">1</span><span class="p">:]</span>
        <span class="n">cov_a_hat_stationarity</span> <span class="o">=</span> <span class="n">cov_a_hat</span><span class="p">[</span><span class="mi">1</span><span class="p">:,</span> <span class="mi">1</span><span class="p">:]</span>
    <span class="k">else</span><span class="p">:</span>
        <span class="n">a_hat_stationarity</span> <span class="o">=</span> <span class="n">a_hat</span>
        <span class="n">cov_a_hat_stationarity</span> <span class="o">=</span> <span class="n">cov_a_hat</span>

    <span class="c1"># Small diagonal jitter for numerical safety</span>
    <span class="n">jitter</span> <span class="o">=</span> <span class="mf">1e-12</span> <span class="o">*</span> <span class="n">np</span><span class="o">.</span><span class="n">eye</span><span class="p">(</span><span class="nb">len</span><span class="p">(</span><span class="n">a_hat_stationarity</span><span class="p">))</span>
    <span class="n">cov_safe</span> <span class="o">=</span> <span class="n">cov_a_hat_stationarity</span> <span class="o">+</span> <span class="n">jitter</span>

    <span class="n">a_boot</span> <span class="o">=</span> <span class="n">rng</span><span class="o">.</span><span class="n">multivariate_normal</span><span class="p">(</span>
        <span class="n">mean</span><span class="o">=</span><span class="n">a_hat_stationarity</span><span class="p">,</span>
        <span class="n">cov</span><span class="o">=</span><span class="n">cov_safe</span><span class="p">,</span>
        <span class="n">size</span><span class="o">=</span><span class="n">B</span>
    <span class="p">)</span>

    <span class="n">stationary_flags</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">zeros</span><span class="p">(</span><span class="n">B</span><span class="p">,</span> <span class="n">dtype</span><span class="o">=</span><span class="nb">int</span><span class="p">)</span>
    <span class="n">min_root_modulus</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">zeros</span><span class="p">(</span><span class="n">B</span><span class="p">)</span>

    <span class="k">for</span> <span class="n">b</span> <span class="ow">in</span> <span class="nb">range</span><span class="p">(</span><span class="n">B</span><span class="p">):</span>
        <span class="n">is_stat</span><span class="p">,</span> <span class="n">roots</span> <span class="o">=</span> <span class="n">is_stationary_ar</span><span class="p">(</span><span class="n">a_boot</span><span class="p">[</span><span class="n">b</span><span class="p">])</span>
        <span class="n">stationary_flags</span><span class="p">[</span><span class="n">b</span><span class="p">]</span> <span class="o">=</span> <span class="nb">int</span><span class="p">(</span><span class="n">is_stat</span><span class="p">)</span>
        <span class="n">min_root_modulus</span><span class="p">[</span><span class="n">b</span><span class="p">]</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">min</span><span class="p">(</span><span class="n">np</span><span class="o">.</span><span class="n">abs</span><span class="p">(</span><span class="n">roots</span><span class="p">))</span>

    <span class="n">point_stationary</span><span class="p">,</span> <span class="n">point_roots</span> <span class="o">=</span> <span class="n">is_stationary_ar</span><span class="p">(</span><span class="n">a_hat_stationarity</span><span class="p">)</span>

    <span class="k">return</span> <span class="p">{</span>
        <span class="s2">"a_boot"</span><span class="p">:</span> <span class="n">a_boot</span><span class="p">,</span>
        <span class="s2">"stationary_flags"</span><span class="p">:</span> <span class="n">stationary_flags</span><span class="p">,</span>
        <span class="s2">"min_root_modulus"</span><span class="p">:</span> <span class="n">min_root_modulus</span><span class="p">,</span>
        <span class="s2">"bootstrap_stationarity_proportion"</span><span class="p">:</span> <span class="nb">float</span><span class="p">(</span><span class="n">stationary_flags</span><span class="o">.</span><span class="n">mean</span><span class="p">()),</span>
        <span class="s2">"point_estimate_stationary"</span><span class="p">:</span> <span class="n">point_stationary</span><span class="p">,</span>
        <span class="s2">"point_roots"</span><span class="p">:</span> <span class="n">point_roots</span><span class="p">,</span>
        <span class="s2">"point_min_root_modulus"</span><span class="p">:</span> <span class="nb">float</span><span class="p">(</span><span class="n">np</span><span class="o">.</span><span class="n">min</span><span class="p">(</span><span class="n">np</span><span class="o">.</span><span class="n">abs</span><span class="p">(</span><span class="n">point_roots</span><span class="p">))),</span>
    <span class="p">}</span>


