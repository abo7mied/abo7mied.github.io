                <span class="sa">f</span><span class="s2">"estimated sigma = </span><span class="si">{</span><span class="n">inference</span><span class="p">[</span><span class="s1">'sigma_hat'</span><span class="p">]</span><span class="si">:</span><span class="s2">.6f</span><span class="si">}</span><span class="s2">; "</span>
                <span class="sa">f</span><span class="s2">"degrees of freedom = </span><span class="si">{</span><span class="n">inference</span><span class="p">[</span><span class="s1">'df'</span><span class="p">]</span><span class="si">}</span><span class="s2">."</span><span class="p">,</span>
