<div class=" highlight hl-ipython3"><pre><span></span><span class="c1"># ============================================================</span>
<span class="c1"># AR Stock PDF Report Generator</span>
<span class="c1"># Up to stationarity analysis</span>
<span class="c1"># ============================================================</span>

<span class="kn">import</span> <span class="nn">os</span>
<span class="kn">import</span> <span class="nn">math</span>
<span class="kn">import</span> <span class="nn">tempfile</span>
<span class="kn">from</span> <span class="nn">datetime</span> <span class="kn">import</span> <span class="n">datetime</span>

<span class="kn">import</span> <span class="nn">numpy</span> <span class="k">as</span> <span class="nn">np</span>
<span class="kn">import</span> <span class="nn">pandas</span> <span class="k">as</span> <span class="nn">pd</span>
<span class="kn">import</span> <span class="nn">matplotlib.pyplot</span> <span class="k">as</span> <span class="nn">plt</span>

<span class="kn">from</span> <span class="nn">scipy.stats</span> <span class="kn">import</span> <span class="n">t</span>
<span class="kn">from</span> <span class="nn">statsmodels.tsa.stattools</span> <span class="kn">import</span> <span class="n">pacf</span>

<span class="kn">from</span> <span class="nn">reportlab.lib</span> <span class="kn">import</span> <span class="n">colors</span>
<span class="kn">from</span> <span class="nn">reportlab.lib.pagesizes</span> <span class="kn">import</span> <span class="n">letter</span>
<span class="kn">from</span> <span class="nn">reportlab.lib.styles</span> <span class="kn">import</span> <span class="n">getSampleStyleSheet</span><span class="p">,</span> <span class="n">ParagraphStyle</span>
<span class="kn">from</span> <span class="nn">reportlab.lib.units</span> <span class="kn">import</span> <span class="n">inch</span>
<span class="kn">from</span> <span class="nn">reportlab.platypus</span> <span class="kn">import</span> <span class="p">(</span>
    <span class="n">SimpleDocTemplate</span><span class="p">,</span>
    <span class="n">Paragraph</span><span class="p">,</span>
    <span class="n">Spacer</span><span class="p">,</span>
    <span class="n">Image</span><span class="p">,</span>
    <span class="n">Table</span><span class="p">,</span>
    <span class="n">TableStyle</span><span class="p">,</span>
    <span class="n">PageBreak</span><span class="p">,</span>
<span class="p">)</span>


<span class="c1"># ============================================================</span>
<span class="c1"># Helper: AR design matrix</span>
<span class="c1"># ============================================================</span>

<span class="k">def</span> <span class="nf">build_ar_design</span><span class="p">(</span><span class="n">series</span><span class="p">,</span> <span class="n">p</span><span class="p">):</span>
<span class="w">    </span><span class="sd">"""</span>
<span class="sd">    Build constant-mean AR(p) regression design matrix.</span>

<span class="sd">    Model:</span>
<span class="sd">        x_t = a_0 + a_1 x_{t-1} + ... + a_p x_{t-p} + epsilon_t</span>

<span class="sd">    Returns:</span>
<span class="sd">        X_p: intercept + lag matrix</span>
<span class="sd">        y_p: aligned target vector</span>
<span class="sd">    """</span>
    <span class="n">series</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">asarray</span><span class="p">(</span><span class="n">series</span><span class="p">)</span><span class="o">.</span><span class="n">ravel</span><span class="p">()</span>

    <span class="n">X_lags</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">column_stack</span><span class="p">([</span>
        <span class="n">series</span><span class="p">[</span><span class="n">p</span> <span class="o">-</span> <span class="mi">1</span> <span class="o">-</span> <span class="n">i</span> <span class="p">:</span> <span class="nb">len</span><span class="p">(</span><span class="n">series</span><span class="p">)</span> <span class="o">-</span> <span class="mi">1</span> <span class="o">-</span> <span class="n">i</span><span class="p">]</span>
        <span class="k">for</span> <span class="n">i</span> <span class="ow">in</span> <span class="nb">range</span><span class="p">(</span><span class="n">p</span><span class="p">)</span>
    <span class="p">])</span>

    <span class="n">X_p</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">column_stack</span><span class="p">([</span><span class="n">np</span><span class="o">.</span><span class="n">ones</span><span class="p">(</span><span class="nb">len</span><span class="p">(</span><span class="n">X_lags</span><span class="p">)),</span> <span class="n">X_lags</span><span class="p">])</span>

    <span class="n">y_p</span> <span class="o">=</span> <span class="n">series</span><span class="p">[</span><span class="n">p</span><span class="p">:]</span>

    <span class="k">return</span> <span class="n">X_p</span><span class="p">,</span> <span class="n">y_p</span>


<span class="k">def</span> <span class="nf">fit_ar_ols</span><span class="p">(</span><span class="n">x_train</span><span class="p">,</span> <span class="n">p</span><span class="p">):</span>
<span class="w">    </span><span class="sd">"""</span>
<span class="sd">    Fit constant-mean AR(p) by least squares.</span>
<span class="sd">    """</span>
    <span class="n">X_train</span><span class="p">,</span> <span class="n">y_train</span> <span class="o">=</span> <span class="n">build_ar_design</span><span class="p">(</span><span class="n">x_train</span><span class="p">,</span> <span class="n">p</span><span class="p">)</span>

    <span class="c1"># More numerically stable than explicit inverse</span>
    <span class="n">a_hat</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">linalg</span><span class="o">.</span><span class="n">lstsq</span><span class="p">(</span><span class="n">X_train</span><span class="p">,</span> <span class="n">y_train</span><span class="p">,</span> <span class="n">rcond</span><span class="o">=</span><span class="kc">None</span><span class="p">)[</span><span class="mi">0</span><span class="p">]</span>

    <span class="n">y_hat</span> <span class="o">=</span> <span class="n">X_train</span> <span class="o">@</span> <span class="n">a_hat</span>
    <span class="n">residuals</span> <span class="o">=</span> <span class="n">y_train</span> <span class="o">-</span> <span class="n">y_hat</span>

    <span class="k">return</span> <span class="p">{</span>
        <span class="s2">"X_train"</span><span class="p">:</span> <span class="n">X_train</span><span class="p">,</span>
        <span class="s2">"y_train"</span><span class="p">:</span> <span class="n">y_train</span><span class="p">,</span>
        <span class="s2">"a_hat"</span><span class="p">:</span> <span class="n">a_hat</span><span class="p">,</span>
        <span class="s2">"y_hat"</span><span class="p">:</span> <span class="n">y_hat</span><span class="p">,</span>
        <span class="s2">"residuals"</span><span class="p">:</span> <span class="n">residuals</span><span class="p">,</span>
    <span class="p">}</span>


<span class="k">def</span> <span class="nf">r2_score</span><span class="p">(</span><span class="n">y_true</span><span class="p">,</span> <span class="n">y_pred</span><span class="p">):</span>
<span class="w">    </span><span class="sd">"""</span>
<span class="sd">    Standard R^2.</span>
<span class="sd">    """</span>
    <span class="n">y_true</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">asarray</span><span class="p">(</span><span class="n">y_true</span><span class="p">)</span><span class="o">.</span><span class="n">ravel</span><span class="p">()</span>
    <span class="n">y_pred</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">asarray</span><span class="p">(</span><span class="n">y_pred</span><span class="p">)</span><span class="o">.</span><span class="n">ravel</span><span class="p">()</span>

    <span class="n">rss</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">dot</span><span class="p">(</span><span class="n">y_true</span> <span class="o">-</span> <span class="n">y_pred</span><span class="p">,</span> <span class="n">y_true</span> <span class="o">-</span> <span class="n">y_pred</span><span class="p">)</span>
    <span class="n">tss</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">dot</span><span class="p">(</span><span class="n">y_true</span> <span class="o">-</span> <span class="n">np</span><span class="o">.</span><span class="n">mean</span><span class="p">(</span><span class="n">y_true</span><span class="p">),</span> <span class="n">y_true</span> <span class="o">-</span> <span class="n">np</span><span class="o">.</span><span class="n">mean</span><span class="p">(</span><span class="n">y_true</span><span class="p">))</span>

    <span class="k">return</span> <span class="mi">1</span> <span class="o">-</span> <span class="n">rss</span> <span class="o">/</span> <span class="n">tss</span>


<span class="c1"># ============================================================</span>
<span class="c1"># PACF + AIC/BIC + Train-Ratio Selection</span>
<span class="c1"># ============================================================</span>

<span class="k">def</span> <span class="nf">select_train_ratio_and_lag</span><span class="p">(</span>
    <span class="n">x</span><span class="p">,</span>
    <span class="n">train_ratio_candidates</span><span class="o">=</span><span class="p">(</span><span class="mf">0.50</span><span class="p">,</span> <span class="mf">0.60</span><span class="p">,</span> <span class="mf">0.70</span><span class="p">,</span> <span class="mf">0.80</span><span class="p">),</span>
    <span class="n">max_lag</span><span class="o">=</span><span class="mi">30</span><span class="p">,</span>
    <span class="n">pacf_buffer</span><span class="o">=</span><span class="mi">5</span><span class="p">,</span>
    <span class="n">selection_rule</span><span class="o">=</span><span class="s2">"bic_then_validation_r2"</span><span class="p">,</span>
<span class="p">):</span>
<span class="w">    </span><span class="sd">"""</span>
<span class="sd">    Jointly search over train ratios and AR lag orders.</span>

<span class="sd">    For each train ratio:</span>
<span class="sd">        1. Compute PACF on training data.</span>
<span class="sd">        2. Use significant PACF lags to define max candidate lag.</span>
<span class="sd">        3. Fit AR(p) models.</span>
<span class="sd">        4. Compute AIC/BIC on training data.</span>
<span class="sd">        5. Compute one-step observed-lag R^2 on test data.</span>

<span class="sd">    Final default rule:</span>
<span class="sd">        - For each train ratio, take BIC-best lag.</span>
<span class="sd">        - Among those, choose best one-step test R^2.</span>
<span class="sd">    """</span>
    <span class="n">x</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">asarray</span><span class="p">(</span><span class="n">x</span><span class="p">)</span><span class="o">.</span><span class="n">ravel</span><span class="p">()</span>

    <span class="n">selection_rows</span> <span class="o">=</span> <span class="p">[]</span>
    <span class="n">pacf_records</span> <span class="o">=</span> <span class="p">{}</span>

    <span class="k">for</span> <span class="n">train_ratio</span> <span class="ow">in</span> <span class="n">train_ratio_candidates</span><span class="p">:</span>
        <span class="n">split_idx</span> <span class="o">=</span> <span class="n">math</span><span class="o">.</span><span class="n">floor</span><span class="p">(</span><span class="n">train_ratio</span> <span class="o">*</span> <span class="nb">len</span><span class="p">(</span><span class="n">x</span><span class="p">))</span>
        <span class="n">x_train</span> <span class="o">=</span> <span class="n">x</span><span class="p">[:</span><span class="n">split_idx</span><span class="p">]</span>
        <span class="n">x_test</span> <span class="o">=</span> <span class="n">x</span><span class="p">[</span><span class="n">split_idx</span><span class="p">:]</span>

        <span class="k">if</span> <span class="nb">len</span><span class="p">(</span><span class="n">x_train</span><span class="p">)</span> <span class="o">&lt;=</span> <span class="n">max_lag</span> <span class="o">+</span> <span class="mi">5</span> <span class="ow">or</span> <span class="nb">len</span><span class="p">(</span><span class="n">x_test</span><span class="p">)</span> <span class="o">&lt;=</span> <span class="n">max_lag</span> <span class="o">+</span> <span class="mi">5</span><span class="p">:</span>
            <span class="k">continue</span>

        <span class="c1"># -----------------------------</span>
        <span class="c1"># PACF for this training split</span>
        <span class="c1"># -----------------------------</span>
        <span class="n">pacf_values</span> <span class="o">=</span> <span class="n">pacf</span><span class="p">(</span><span class="n">x_train</span><span class="p">,</span> <span class="n">nlags</span><span class="o">=</span><span class="n">max_lag</span><span class="p">,</span> <span class="n">method</span><span class="o">=</span><span class="s2">"ywm"</span><span class="p">)</span>
        <span class="n">n_train</span> <span class="o">=</span> <span class="nb">len</span><span class="p">(</span><span class="n">x_train</span><span class="p">)</span>
        <span class="n">threshold</span> <span class="o">=</span> <span class="mf">1.96</span> <span class="o">/</span> <span class="n">np</span><span class="o">.</span><span class="n">sqrt</span><span class="p">(</span><span class="n">n_train</span><span class="p">)</span>
        <span class="n">lags</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">arange</span><span class="p">(</span><span class="nb">len</span><span class="p">(</span><span class="n">pacf_values</span><span class="p">))</span>

        <span class="n">significant_lags</span> <span class="o">=</span> <span class="n">lags</span><span class="p">[</span>
            <span class="p">(</span><span class="n">np</span><span class="o">.</span><span class="n">abs</span><span class="p">(</span><span class="n">pacf_values</span><span class="p">)</span> <span class="o">&gt;</span> <span class="n">threshold</span><span class="p">)</span> <span class="o">&amp;</span> <span class="p">(</span><span class="n">lags</span> <span class="o">&gt;</span> <span class="mi">0</span><span class="p">)</span>
        <span class="p">]</span>

        <span class="k">if</span> <span class="nb">len</span><span class="p">(</span><span class="n">significant_lags</span><span class="p">)</span> <span class="o">&gt;</span> <span class="mi">0</span><span class="p">:</span>
            <span class="n">pacf_suggested_lag</span> <span class="o">=</span> <span class="nb">int</span><span class="p">(</span><span class="n">significant_lags</span><span class="o">.</span><span class="n">max</span><span class="p">())</span>
        <span class="k">else</span><span class="p">:</span>
            <span class="n">pacf_suggested_lag</span> <span class="o">=</span> <span class="mi">1</span>

        <span class="n">pacf_informed_max_lag</span> <span class="o">=</span> <span class="nb">min</span><span class="p">(</span>
            <span class="n">max_lag</span><span class="p">,</span>
            <span class="nb">max</span><span class="p">(</span><span class="mi">5</span><span class="p">,</span> <span class="n">pacf_suggested_lag</span> <span class="o">+</span> <span class="n">pacf_buffer</span><span class="p">)</span>
        <span class="p">)</span>

        <span class="n">pacf_records</span><span class="p">[</span><span class="n">train_ratio</span><span class="p">]</span> <span class="o">=</span> <span class="p">{</span>
            <span class="s2">"split_idx"</span><span class="p">:</span> <span class="n">split_idx</span><span class="p">,</span>
            <span class="s2">"x_train"</span><span class="p">:</span> <span class="n">x_train</span><span class="p">,</span>
            <span class="s2">"x_test"</span><span class="p">:</span> <span class="n">x_test</span><span class="p">,</span>
            <span class="s2">"pacf_values"</span><span class="p">:</span> <span class="n">pacf_values</span><span class="p">,</span>
            <span class="s2">"threshold"</span><span class="p">:</span> <span class="n">threshold</span><span class="p">,</span>
            <span class="s2">"lags"</span><span class="p">:</span> <span class="n">lags</span><span class="p">,</span>
            <span class="s2">"significant_lags"</span><span class="p">:</span> <span class="n">significant_lags</span><span class="p">,</span>
            <span class="s2">"PACF_SUGGESTED_LAG"</span><span class="p">:</span> <span class="n">pacf_suggested_lag</span><span class="p">,</span>
            <span class="s2">"PACF_INFORMED_MAX_LAG"</span><span class="p">:</span> <span class="n">pacf_informed_max_lag</span><span class="p">,</span>
        <span class="p">}</span>

        <span class="c1"># -----------------------------</span>
        <span class="c1"># AIC/BIC over candidate lags</span>
        <span class="c1"># -----------------------------</span>
        <span class="k">for</span> <span class="n">p</span> <span class="ow">in</span> <span class="nb">range</span><span class="p">(</span><span class="mi">1</span><span class="p">,</span> <span class="n">pacf_informed_max_lag</span> <span class="o">+</span> <span class="mi">1</span><span class="p">):</span>

            <span class="k">if</span> <span class="nb">len</span><span class="p">(</span><span class="n">x_train</span><span class="p">)</span> <span class="o">&lt;=</span> <span class="n">p</span> <span class="o">+</span> <span class="mi">1</span> <span class="ow">or</span> <span class="nb">len</span><span class="p">(</span><span class="n">x_test</span><span class="p">)</span> <span class="o">&lt;=</span> <span class="n">p</span> <span class="o">+</span> <span class="mi">1</span><span class="p">:</span>
                <span class="k">continue</span>

            <span class="n">X_train_p</span><span class="p">,</span> <span class="n">y_train_p</span> <span class="o">=</span> <span class="n">build_ar_design</span><span class="p">(</span><span class="n">x_train</span><span class="p">,</span> <span class="n">p</span><span class="p">)</span>
            <span class="n">X_test_p</span><span class="p">,</span> <span class="n">y_test_p</span> <span class="o">=</span> <span class="n">build_ar_design</span><span class="p">(</span><span class="n">x_test</span><span class="p">,</span> <span class="n">p</span><span class="p">)</span>

            <span class="n">a_hat_p</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">linalg</span><span class="o">.</span><span class="n">lstsq</span><span class="p">(</span><span class="n">X_train_p</span><span class="p">,</span> <span class="n">y_train_p</span><span class="p">,</span> <span class="n">rcond</span><span class="o">=</span><span class="kc">None</span><span class="p">)[</span><span class="mi">0</span><span class="p">]</span>

            <span class="n">y_train_hat_p</span> <span class="o">=</span> <span class="n">X_train_p</span> <span class="o">@</span> <span class="n">a_hat_p</span>
            <span class="n">y_test_hat_p</span> <span class="o">=</span> <span class="n">X_test_p</span> <span class="o">@</span> <span class="n">a_hat_p</span>

            <span class="n">train_resid_p</span> <span class="o">=</span> <span class="n">y_train_p</span> <span class="o">-</span> <span class="n">y_train_hat_p</span>
            <span class="n">test_resid_p</span> <span class="o">=</span> <span class="n">y_test_p</span> <span class="o">-</span> <span class="n">y_test_hat_p</span>

            <span class="n">RSS_train_p</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">dot</span><span class="p">(</span><span class="n">train_resid_p</span><span class="p">,</span> <span class="n">train_resid_p</span><span class="p">)</span>
            <span class="n">RSS_test_p</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">dot</span><span class="p">(</span><span class="n">test_resid_p</span><span class="p">,</span> <span class="n">test_resid_p</span><span class="p">)</span>

            <span class="n">n_p</span> <span class="o">=</span> <span class="nb">len</span><span class="p">(</span><span class="n">y_train_p</span><span class="p">)</span>
            <span class="n">k_p</span> <span class="o">=</span> <span class="n">X_train_p</span><span class="o">.</span><span class="n">shape</span><span class="p">[</span><span class="mi">1</span><span class="p">]</span>

            <span class="n">sigma2_hat_p</span> <span class="o">=</span> <span class="n">RSS_train_p</span> <span class="o">/</span> <span class="n">n_p</span>

            <span class="n">AIC_p</span> <span class="o">=</span> <span class="n">n_p</span> <span class="o">*</span> <span class="n">np</span><span class="o">.</span><span class="n">log</span><span class="p">(</span><span class="n">sigma2_hat_p</span><span class="p">)</span> <span class="o">+</span> <span class="mi">2</span> <span class="o">*</span> <span class="n">k_p</span>
            <span class="n">BIC_p</span> <span class="o">=</span> <span class="n">n_p</span> <span class="o">*</span> <span class="n">np</span><span class="o">.</span><span class="n">log</span><span class="p">(</span><span class="n">sigma2_hat_p</span><span class="p">)</span> <span class="o">+</span> <span class="n">k_p</span> <span class="o">*</span> <span class="n">np</span><span class="o">.</span><span class="n">log</span><span class="p">(</span><span class="n">n_p</span><span class="p">)</span>

            <span class="n">Test_R2_OneStep_p</span> <span class="o">=</span> <span class="n">r2_score</span><span class="p">(</span><span class="n">y_test_p</span><span class="p">,</span> <span class="n">y_test_hat_p</span><span class="p">)</span>

            <span class="n">selection_rows</span><span class="o">.</span><span class="n">append</span><span class="p">({</span>
                <span class="s2">"Train_Ratio"</span><span class="p">:</span> <span class="n">train_ratio</span><span class="p">,</span>
                <span class="s2">"Train_Size"</span><span class="p">:</span> <span class="nb">len</span><span class="p">(</span><span class="n">x_train</span><span class="p">),</span>
                <span class="s2">"Test_Size"</span><span class="p">:</span> <span class="nb">len</span><span class="p">(</span><span class="n">x_test</span><span class="p">),</span>
                <span class="s2">"PACF_Suggested_Lag"</span><span class="p">:</span> <span class="n">pacf_suggested_lag</span><span class="p">,</span>
                <span class="s2">"PACF_Informed_Max_Lag"</span><span class="p">:</span> <span class="n">pacf_informed_max_lag</span><span class="p">,</span>
                <span class="s2">"Lag_Order"</span><span class="p">:</span> <span class="n">p</span><span class="p">,</span>
                <span class="s2">"RSS_Train"</span><span class="p">:</span> <span class="n">RSS_train_p</span><span class="p">,</span>
                <span class="s2">"RSS_Test"</span><span class="p">:</span> <span class="n">RSS_test_p</span><span class="p">,</span>
                <span class="s2">"Sigma2_hat"</span><span class="p">:</span> <span class="n">sigma2_hat_p</span><span class="p">,</span>
                <span class="s2">"AIC"</span><span class="p">:</span> <span class="n">AIC_p</span><span class="p">,</span>
                <span class="s2">"BIC"</span><span class="p">:</span> <span class="n">BIC_p</span><span class="p">,</span>
                <span class="s2">"Test_R2_OneStep"</span><span class="p">:</span> <span class="n">Test_R2_OneStep_p</span><span class="p">,</span>
            <span class="p">})</span>

    <span class="n">selection_df</span> <span class="o">=</span> <span class="n">pd</span><span class="o">.</span><span class="n">DataFrame</span><span class="p">(</span><span class="n">selection_rows</span><span class="p">)</span>

    <span class="k">if</span> <span class="n">selection_df</span><span class="o">.</span><span class="n">empty</span><span class="p">:</span>
        <span class="k">raise</span> <span class="ne">ValueError</span><span class="p">(</span><span class="s2">"No valid train-ratio / lag-order combinations were found."</span><span class="p">)</span>

    <span class="n">aic_best_by_ratio</span> <span class="o">=</span> <span class="p">(</span>
        <span class="n">selection_df</span>
        <span class="o">.</span><span class="n">sort_values</span><span class="p">([</span><span class="s2">"Train_Ratio"</span><span class="p">,</span> <span class="s2">"AIC"</span><span class="p">])</span>
        <span class="o">.</span><span class="n">groupby</span><span class="p">(</span><span class="s2">"Train_Ratio"</span><span class="p">)</span>
        <span class="o">.</span><span class="n">head</span><span class="p">(</span><span class="mi">1</span><span class="p">)</span>
        <span class="o">.</span><span class="n">reset_index</span><span class="p">(</span><span class="n">drop</span><span class="o">=</span><span class="kc">True</span><span class="p">)</span>
    <span class="p">)</span>

    <span class="n">bic_best_by_ratio</span> <span class="o">=</span> <span class="p">(</span>
        <span class="n">selection_df</span>
        <span class="o">.</span><span class="n">sort_values</span><span class="p">([</span><span class="s2">"Train_Ratio"</span><span class="p">,</span> <span class="s2">"BIC"</span><span class="p">])</span>
        <span class="o">.</span><span class="n">groupby</span><span class="p">(</span><span class="s2">"Train_Ratio"</span><span class="p">)</span>
        <span class="o">.</span><span class="n">head</span><span class="p">(</span><span class="mi">1</span><span class="p">)</span>
        <span class="o">.</span><span class="n">reset_index</span><span class="p">(</span><span class="n">drop</span><span class="o">=</span><span class="kc">True</span><span class="p">)</span>
    <span class="p">)</span>

    <span class="k">if</span> <span class="n">selection_rule</span> <span class="o">==</span> <span class="s2">"bic_then_validation_r2"</span><span class="p">:</span>
        <span class="n">best_row</span> <span class="o">=</span> <span class="n">bic_best_by_ratio</span><span class="o">.</span><span class="n">loc</span><span class="p">[</span>
            <span class="n">bic_best_by_ratio</span><span class="p">[</span><span class="s2">"Test_R2_OneStep"</span><span class="p">]</span><span class="o">.</span><span class="n">idxmax</span><span class="p">()</span>
        <span class="p">]</span>
    <span class="k">elif</span> <span class="n">selection_rule</span> <span class="o">==</span> <span class="s2">"aic_then_validation_r2"</span><span class="p">:</span>
        <span class="n">best_row</span> <span class="o">=</span> <span class="n">aic_best_by_ratio</span><span class="o">.</span><span class="n">loc</span><span class="p">[</span>
            <span class="n">aic_best_by_ratio</span><span class="p">[</span><span class="s2">"Test_R2_OneStep"</span><span class="p">]</span><span class="o">.</span><span class="n">idxmax</span><span class="p">()</span>
        <span class="p">]</span>
    <span class="k">elif</span> <span class="n">selection_rule</span> <span class="o">==</span> <span class="s2">"global_best_test_r2"</span><span class="p">:</span>
        <span class="n">best_row</span> <span class="o">=</span> <span class="n">selection_df</span><span class="o">.</span><span class="n">loc</span><span class="p">[</span>
            <span class="n">selection_df</span><span class="p">[</span><span class="s2">"Test_R2_OneStep"</span><span class="p">]</span><span class="o">.</span><span class="n">idxmax</span><span class="p">()</span>
        <span class="p">]</span>
    <span class="k">else</span><span class="p">:</span>
        <span class="k">raise</span> <span class="ne">ValueError</span><span class="p">(</span><span class="sa">f</span><span class="s2">"Unknown selection_rule: </span><span class="si">{</span><span class="n">selection_rule</span><span class="si">}</span><span class="s2">"</span><span class="p">)</span>

    <span class="n">train_ratio</span> <span class="o">=</span> <span class="nb">float</span><span class="p">(</span><span class="n">best_row</span><span class="p">[</span><span class="s2">"Train_Ratio"</span><span class="p">])</span>
    <span class="n">lag_order</span> <span class="o">=</span> <span class="nb">int</span><span class="p">(</span><span class="n">best_row</span><span class="p">[</span><span class="s2">"Lag_Order"</span><span class="p">])</span>

    <span class="k">return</span> <span class="p">{</span>
        <span class="s2">"selection_df"</span><span class="p">:</span> <span class="n">selection_df</span><span class="p">,</span>
        <span class="s2">"aic_best_by_ratio"</span><span class="p">:</span> <span class="n">aic_best_by_ratio</span><span class="p">,</span>
        <span class="s2">"bic_best_by_ratio"</span><span class="p">:</span> <span class="n">bic_best_by_ratio</span><span class="p">,</span>
        <span class="s2">"pacf_records"</span><span class="p">:</span> <span class="n">pacf_records</span><span class="p">,</span>
        <span class="s2">"best_row"</span><span class="p">:</span> <span class="n">best_row</span><span class="p">,</span>
        <span class="s2">"TRAIN_RATIO"</span><span class="p">:</span> <span class="n">train_ratio</span><span class="p">,</span>
        <span class="s2">"LAG_ORDER"</span><span class="p">:</span> <span class="n">lag_order</span><span class="p">,</span>
    <span class="p">}</span>


