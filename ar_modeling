<div class=" highlight hl-ipython3"><pre><span></span><span class="kn">import</span> <span class="nn">numpy</span> <span class="k">as</span> <span class="nn">np</span>
<span class="kn">import</span> <span class="nn">matplotlib.pyplot</span> <span class="k">as</span> <span class="nn">plt</span>
<span class="kn">import</span> <span class="nn">math</span>

<span class="n">H</span> <span class="o">=</span> <span class="mi">50</span>  <span class="c1"># forecast block size</span>

<span class="c1"># Flatten for safety</span>
<span class="n">x_train_flat</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">asarray</span><span class="p">(</span><span class="n">x_train</span><span class="p">)</span><span class="o">.</span><span class="n">ravel</span><span class="p">()</span>
<span class="n">x_test_flat</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">asarray</span><span class="p">(</span><span class="n">x_test</span><span class="p">)</span><span class="o">.</span><span class="n">ravel</span><span class="p">()</span>
<span class="n">a_hat_flat</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">asarray</span><span class="p">(</span><span class="n">a_hat</span><span class="p">)</span><span class="o">.</span><span class="n">ravel</span><span class="p">()</span>

<span class="n">preds</span> <span class="o">=</span> <span class="p">[]</span>
<span class="n">actuals</span> <span class="o">=</span> <span class="p">[]</span>
<span class="n">pred_indices_inside_test</span> <span class="o">=</span> <span class="p">[]</span>

<span class="c1"># Store block-start indices inside the test set for vertical lines</span>
<span class="n">block_boundary_indices_inside_test</span> <span class="o">=</span> <span class="p">[]</span>

<span class="c1"># Start forecasting at the first test point</span>
<span class="n">block_start</span> <span class="o">=</span> <span class="mi">0</span>

<span class="k">while</span> <span class="n">block_start</span> <span class="o">&lt;</span> <span class="nb">len</span><span class="p">(</span><span class="n">x_test_flat</span><span class="p">):</span>

    <span class="n">block_boundary_indices_inside_test</span><span class="o">.</span><span class="n">append</span><span class="p">(</span><span class="n">block_start</span><span class="p">)</span>

    <span class="c1"># True history available at forecast origin:</span>
    <span class="c1"># all training data + revealed test data up to this block boundary.</span>
    <span class="n">history</span> <span class="o">=</span> <span class="nb">list</span><span class="p">(</span><span class="n">np</span><span class="o">.</span><span class="n">concatenate</span><span class="p">([</span>
        <span class="n">x_train_flat</span><span class="p">,</span>
        <span class="n">x_test_flat</span><span class="p">[:</span><span class="n">block_start</span><span class="p">]</span>
    <span class="p">]))</span>

    <span class="c1"># Forecast up to H steps recursively</span>
    <span class="n">block_preds</span> <span class="o">=</span> <span class="p">[]</span>
    <span class="n">steps_this_block</span> <span class="o">=</span> <span class="nb">min</span><span class="p">(</span><span class="n">H</span><span class="p">,</span> <span class="nb">len</span><span class="p">(</span><span class="n">x_test_flat</span><span class="p">)</span> <span class="o">-</span> <span class="n">block_start</span><span class="p">)</span>

    <span class="k">for</span> <span class="n">step</span> <span class="ow">in</span> <span class="nb">range</span><span class="p">(</span><span class="n">steps_this_block</span><span class="p">):</span>
        <span class="n">lag_values</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">array</span><span class="p">([</span>
            <span class="n">history</span><span class="p">[</span><span class="o">-</span><span class="mi">1</span> <span class="o">-</span> <span class="n">i</span><span class="p">]</span>
            <span class="k">for</span> <span class="n">i</span> <span class="ow">in</span> <span class="nb">range</span><span class="p">(</span><span class="n">LAG_ORDER</span><span class="p">)</span>
        <span class="p">],</span> <span class="n">dtype</span><span class="o">=</span><span class="nb">float</span><span class="p">)</span><span class="o">.</span><span class="n">ravel</span><span class="p">()</span>
        <span class="n">lag_vector</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">concatenate</span><span class="p">(([</span><span class="mf">1.0</span><span class="p">],</span> <span class="n">lag_values</span><span class="p">))</span>

        <span class="n">next_pred</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">dot</span><span class="p">(</span><span class="n">lag_vector</span><span class="p">,</span> <span class="n">a_hat_flat</span><span class="p">)</span>
        <span class="n">block_preds</span><span class="o">.</span><span class="n">append</span><span class="p">(</span><span class="n">next_pred</span><span class="p">)</span>

        <span class="c1"># Recursive feeding within the block</span>
        <span class="n">history</span><span class="o">.</span><span class="n">append</span><span class="p">(</span><span class="n">next_pred</span><span class="p">)</span>

    <span class="c1"># Store predictions and corresponding true future values</span>
    <span class="n">preds</span><span class="o">.</span><span class="n">extend</span><span class="p">(</span><span class="n">block_preds</span><span class="p">)</span>
    <span class="n">actuals</span><span class="o">.</span><span class="n">extend</span><span class="p">(</span><span class="n">x_test_flat</span><span class="p">[</span><span class="n">block_start</span> <span class="p">:</span> <span class="n">block_start</span> <span class="o">+</span> <span class="n">steps_this_block</span><span class="p">])</span>
    <span class="n">pred_indices_inside_test</span><span class="o">.</span><span class="n">extend</span><span class="p">(</span>
        <span class="nb">range</span><span class="p">(</span><span class="n">block_start</span><span class="p">,</span> <span class="n">block_start</span> <span class="o">+</span> <span class="n">steps_this_block</span><span class="p">)</span>
    <span class="p">)</span>

    <span class="c1"># Reveal true values through this block, then move ahead by H</span>
    <span class="n">block_start</span> <span class="o">+=</span> <span class="n">H</span>

