<span class="p">})</span>

<span class="n">display</span><span class="p">(</span><span class="n">coef_ci_df</span><span class="p">)</span>

<span class="nb">print</span><span class="p">(</span><span class="sa">f</span><span class="s2">"t critical value with df=</span><span class="si">{</span><span class="n">df</span><span class="si">}</span><span class="s2">: </span><span class="si">{</span><span class="n">t_crit</span><span class="si">:</span><span class="s2">.4f</span><span class="si">}</span><span class="s2">"</span><span class="p">)</span>
