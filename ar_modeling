<div class=" highlight hl-ipython3"><pre><span></span><span class="c1"># Goodness-of-fit evaluation</span>

<span class="n">x_test_hat</span> <span class="o">=</span> <span class="n">X_test</span> <span class="o">@</span> <span class="n">a_hat</span>

<span class="c1"># Residuals on aligned test slice</span>
<span class="n">epsilon_hat</span> <span class="o">=</span> <span class="n">x_test_slice</span> <span class="o">-</span> <span class="n">x_test_hat</span>

<span class="c1"># R^2 on aligned test slice</span>
<span class="n">centered_x_test</span> <span class="o">=</span> <span class="n">x_test_slice</span> <span class="o">-</span> <span class="n">np</span><span class="o">.</span><span class="n">mean</span><span class="p">(</span><span class="n">x_test_slice</span><span class="p">)</span>

<span class="n">RSS</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">dot</span><span class="p">(</span><span class="n">epsilon_hat</span><span class="p">,</span> <span class="n">epsilon_hat</span><span class="p">)</span>
<span class="n">TSS</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">dot</span><span class="p">(</span><span class="n">centered_x_test</span><span class="p">,</span> <span class="n">centered_x_test</span><span class="p">)</span>

<span class="n">R_squared</span> <span class="o">=</span> <span class="mi">1</span> <span class="o">-</span> <span class="p">(</span><span class="n">RSS</span> <span class="o">/</span> <span class="n">TSS</span><span class="p">)</span>

<span class="nb">print</span><span class="p">(</span><span class="n">R_squared</span><span class="p">)</span>
</pre></div>

