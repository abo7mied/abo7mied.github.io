<div class=" highlight hl-ipython3"><pre><span></span><span class="c1"># Bootstrap-based stationarity robustness</span>
<span class="n">B</span> <span class="o">=</span> <span class="mi">5000</span>
<span class="n">ALPHA</span> <span class="o">=</span> <span class="mf">0.05</span>
<span class="n">RNG_SEED</span> <span class="o">=</span> <span class="mi">42</span>

<span class="n">epsilon_train_hat</span> <span class="o">=</span> <span class="n">x_train_slice</span> <span class="o">-</span> <span class="n">x_train_hat</span>
<span class="n">sigma2_hat</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">dot</span><span class="p">(</span><span class="n">epsilon_train_hat</span><span class="p">,</span> <span class="n">epsilon_train_hat</span><span class="p">)</span> <span class="o">/</span> <span class="nb">len</span><span class="p">(</span><span class="n">x_train_slice</span><span class="p">)</span>

<span class="n">XtX_inv</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">linalg</span><span class="o">.</span><span class="n">inv</span><span class="p">(</span><span class="n">np</span><span class="o">.</span><span class="n">matmul</span><span class="p">(</span><span class="n">X_train</span><span class="o">.</span><span class="n">T</span><span class="p">,</span> <span class="n">X_train</span><span class="p">))</span>
<span class="n">cov_a_hat</span> <span class="o">=</span> <span class="n">sigma2_hat</span> <span class="o">*</span> <span class="n">XtX_inv</span>

<span class="n">rng</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">random</span><span class="o">.</span><span class="n">default_rng</span><span class="p">(</span><span class="n">RNG_SEED</span><span class="p">)</span>

<span class="c1"># Stationarity depends on the AR lag coefficients only, not the intercept.</span>
<span class="n">a_hat_ar</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">asarray</span><span class="p">(</span><span class="n">a_hat</span><span class="p">)</span><span class="o">.</span><span class="n">ravel</span><span class="p">()[</span><span class="mi">1</span><span class="p">:]</span>
<span class="n">cov_a_hat_ar</span> <span class="o">=</span> <span class="n">cov_a_hat</span><span class="p">[</span><span class="mi">1</span><span class="p">:,</span> <span class="mi">1</span><span class="p">:]</span>

<span class="n">a_boot</span> <span class="o">=</span> <span class="n">rng</span><span class="o">.</span><span class="n">multivariate_normal</span><span class="p">(</span><span class="n">mean</span><span class="o">=</span><span class="n">a_hat_ar</span><span class="p">,</span> <span class="n">cov</span><span class="o">=</span><span class="n">cov_a_hat_ar</span><span class="p">,</span> <span class="n">size</span><span class="o">=</span><span class="n">B</span><span class="p">)</span>

<span class="k">def</span> <span class="nf">is_stationary_ar</span><span class="p">(</span><span class="n">coeffs</span><span class="p">):</span>
    <span class="n">poly_coeffs</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">concatenate</span><span class="p">((</span><span class="o">-</span><span class="n">np</span><span class="o">.</span><span class="n">array</span><span class="p">(</span><span class="n">coeffs</span><span class="p">)[::</span><span class="o">-</span><span class="mi">1</span><span class="p">],</span> <span class="n">np</span><span class="o">.</span><span class="n">array</span><span class="p">([</span><span class="mf">1.0</span><span class="p">])))</span>
    <span class="n">roots</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">roots</span><span class="p">(</span><span class="n">poly_coeffs</span><span class="p">)</span>
    <span class="k">return</span> <span class="n">np</span><span class="o">.</span><span class="n">all</span><span class="p">(</span><span class="n">np</span><span class="o">.</span><span class="n">abs</span><span class="p">(</span><span class="n">roots</span><span class="p">)</span> <span class="o">&gt;</span> <span class="mi">1</span><span class="p">),</span> <span class="n">roots</span>

<span class="n">point_estimate_stationary</span><span class="p">,</span> <span class="n">point_roots</span> <span class="o">=</span> <span class="n">is_stationary_ar</span><span class="p">(</span><span class="n">a_hat_ar</span><span class="p">)</span>

<span class="n">stationary_flags</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">zeros</span><span class="p">(</span><span class="n">B</span><span class="p">,</span> <span class="n">dtype</span><span class="o">=</span><span class="nb">int</span><span class="p">)</span>
<span class="n">min_root_modulus</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">zeros</span><span class="p">(</span><span class="n">B</span><span class="p">)</span>

<span class="k">for</span> <span class="n">b</span> <span class="ow">in</span> <span class="nb">range</span><span class="p">(</span><span class="n">B</span><span class="p">):</span>
    <span class="n">is_stat</span><span class="p">,</span> <span class="n">roots</span> <span class="o">=</span> <span class="n">is_stationary_ar</span><span class="p">(</span><span class="n">a_boot</span><span class="p">[</span><span class="n">b</span><span class="p">])</span>
    <span class="n">stationary_flags</span><span class="p">[</span><span class="n">b</span><span class="p">]</span> <span class="o">=</span> <span class="nb">int</span><span class="p">(</span><span class="n">is_stat</span><span class="p">)</span>
    <span class="n">min_root_modulus</span><span class="p">[</span><span class="n">b</span><span class="p">]</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">min</span><span class="p">(</span><span class="n">np</span><span class="o">.</span><span class="n">abs</span><span class="p">(</span><span class="n">roots</span><span class="p">))</span>

<span class="n">p_stat_hat</span> <span class="o">=</span> <span class="n">stationary_flags</span><span class="o">.</span><span class="n">mean</span><span class="p">()</span>

<span class="nb">print</span><span class="p">(</span><span class="s2">"Point estimate AR coefficients:"</span><span class="p">,</span> <span class="n">a_hat_ar</span><span class="p">)</span>
<span class="nb">print</span><span class="p">(</span><span class="s2">"Point estimate stationary:"</span><span class="p">,</span> <span class="n">point_estimate_stationary</span><span class="p">)</span>
<span class="nb">print</span><span class="p">(</span><span class="s2">"Estimated sigma^2:"</span><span class="p">,</span> <span class="n">sigma2_hat</span><span class="p">)</span>
<span class="nb">print</span><span class="p">(</span><span class="s2">"Bootstrap stationarity proportion:"</span><span class="p">,</span> <span class="n">p_stat_hat</span><span class="p">)</span>
<span class="nb">print</span><span class="p">(</span><span class="s2">"Decision at alpha ="</span><span class="p">,</span> <span class="n">ALPHA</span><span class="p">,</span> <span class="s2">":"</span><span class="p">,</span> <span class="s2">"Accept stationarity"</span> <span class="k">if</span> <span class="n">p_stat_hat</span> <span class="o">&gt;=</span> <span class="mi">1</span> <span class="o">-</span> <span class="n">ALPHA</span> <span class="k">else</span> <span class="s2">"Reject stationarity"</span><span class="p">)</span>

<span class="c1"># --------------------------------------------------</span>
<span class="c1"># Colored histogram: red below 1, green above 1</span>
<span class="c1"># --------------------------------------------------</span>
<span class="n">counts</span><span class="p">,</span> <span class="n">bin_edges</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">histogram</span><span class="p">(</span><span class="n">min_root_modulus</span><span class="p">,</span> <span class="n">bins</span><span class="o">=</span><span class="mi">40</span><span class="p">)</span>
<span class="n">bin_centers</span> <span class="o">=</span> <span class="mf">0.5</span> <span class="o">*</span> <span class="p">(</span><span class="n">bin_edges</span><span class="p">[:</span><span class="o">-</span><span class="mi">1</span><span class="p">]</span> <span class="o">+</span> <span class="n">bin_edges</span><span class="p">[</span><span class="mi">1</span><span class="p">:])</span>
<span class="n">bin_widths</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">diff</span><span class="p">(</span><span class="n">bin_edges</span><span class="p">)</span>

<span class="n">plt</span><span class="o">.</span><span class="n">figure</span><span class="p">(</span><span class="n">figsize</span><span class="o">=</span><span class="p">(</span><span class="mi">8</span><span class="p">,</span> <span class="mi">4</span><span class="p">))</span>

<span class="k">for</span> <span class="n">i</span> <span class="ow">in</span> <span class="nb">range</span><span class="p">(</span><span class="nb">len</span><span class="p">(</span><span class="n">counts</span><span class="p">)):</span>
    <span class="n">color</span> <span class="o">=</span> <span class="s2">"green"</span> <span class="k">if</span> <span class="n">bin_centers</span><span class="p">[</span><span class="n">i</span><span class="p">]</span> <span class="o">&gt;</span> <span class="mf">1.0</span> <span class="k">else</span> <span class="s2">"red"</span>
    <span class="n">plt</span><span class="o">.</span><span class="n">bar</span><span class="p">(</span>
        <span class="n">bin_edges</span><span class="p">[</span><span class="n">i</span><span class="p">],</span>
        <span class="n">counts</span><span class="p">[</span><span class="n">i</span><span class="p">],</span>
