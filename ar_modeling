            <span class="n">add_image</span><span class="p">(</span><span class="n">story</span><span class="p">,</span> <span class="n">figure_paths</span><span class="p">[</span><span class="s2">"aic_bic"</span><span class="p">])</span>

        <span class="c1"># Inference</span>
        <span class="k">if</span> <span class="n">flags</span><span class="p">[</span><span class="s2">"include_inference"</span><span class="p">]:</span>
