<span class="n">H</span> <span class="o">=</span> <span class="mi">1</span>   <span class="c1"># h-steps ahead</span>

<span class="c1"># --------------------------------------------------</span>
<span class="c1"># Build h-step-ahead test matrix</span>
<span class="c1"># Predict x_{t+H} using [1, x_t, x_{t-1}, ..., x_{t-p+1}]</span>
<span class="c1"># --------------------------------------------------</span>
<span class="n">X_test_h_lags</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">column_stack</span><span class="p">([</span>
    <span class="n">x_test</span><span class="p">[</span><span class="n">LAG_ORDER</span> <span class="o">-</span> <span class="mi">1</span> <span class="o">-</span> <span class="n">i</span> <span class="p">:</span> <span class="nb">len</span><span class="p">(</span><span class="n">x_test</span><span class="p">)</span> <span class="o">-</span> <span class="n">H</span> <span class="o">-</span> <span class="n">i</span><span class="p">]</span>
    <span class="k">for</span> <span class="n">i</span> <span class="ow">in</span> <span class="nb">range</span><span class="p">(</span><span class="n">LAG_ORDER</span><span class="p">)</span>
<span class="p">])</span>

<span class="n">X_test_h</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">column_stack</span><span class="p">([</span><span class="n">np</span><span class="o">.</span><span class="n">ones</span><span class="p">(</span><span class="nb">len</span><span class="p">(</span><span class="n">X_test_h_lags</span><span class="p">)),</span> <span class="n">X_test_h_lags</span><span class="p">])</span>

<span class="n">x_test_h_slice</span> <span class="o">=</span> <span class="n">x_test</span><span class="p">[</span><span class="n">LAG_ORDER</span> <span class="o">-</span> <span class="mi">1</span> <span class="o">+</span> <span class="n">H</span><span class="p">:]</span>

<span class="c1"># h-step-ahead matrix predictions</span>
<span class="n">x_test_hat_h</span> <span class="o">=</span> <span class="n">X_test_h</span> <span class="o">@</span> <span class="n">a_hat</span>

<span class="c1"># Flatten for plotting safety</span>
<span class="n">x_test_plot</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">asarray</span><span class="p">(</span><span class="n">x_test_h_slice</span><span class="p">)</span><span class="o">.</span><span class="n">ravel</span><span class="p">()</span>
<span class="n">x_test_hat_plot</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">asarray</span><span class="p">(</span><span class="n">x_test_hat_h</span><span class="p">)</span><span class="o">.</span><span class="n">ravel</span><span class="p">()</span>

<span class="c1"># --------------------------------------------------</span>
<span class="c1"># Time axis alignment</span>
<span class="c1"># --------------------------------------------------</span>
<span class="n">split_idx</span> <span class="o">=</span> <span class="n">math</span><span class="o">.</span><span class="n">floor</span><span class="p">(</span><span class="n">TRAIN_RATIO</span> <span class="o">*</span> <span class="nb">len</span><span class="p">(</span><span class="n">x</span><span class="p">))</span>

<span class="k">try</span><span class="p">:</span>
    <span class="n">time_axis_full</span> <span class="o">=</span> <span class="n">x_df</span><span class="o">.</span><span class="n">index</span>
    <span class="n">time_axis_test</span> <span class="o">=</span> <span class="n">time_axis_full</span><span class="p">[</span><span class="n">split_idx</span> <span class="o">+</span> <span class="n">LAG_ORDER</span> <span class="o">-</span> <span class="mi">1</span> <span class="o">+</span> <span class="n">H</span><span class="p">:]</span>
<span class="k">except</span><span class="p">:</span>
    <span class="n">time_axis_full</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">arange</span><span class="p">(</span><span class="nb">len</span><span class="p">(</span><span class="n">x</span><span class="p">))</span>
    <span class="n">time_axis_test</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">arange</span><span class="p">(</span>
        <span class="n">split_idx</span> <span class="o">+</span> <span class="n">LAG_ORDER</span> <span class="o">-</span> <span class="mi">1</span> <span class="o">+</span> <span class="n">H</span><span class="p">,</span>
        <span class="n">split_idx</span> <span class="o">+</span> <span class="n">LAG_ORDER</span> <span class="o">-</span> <span class="mi">1</span> <span class="o">+</span> <span class="n">H</span> <span class="o">+</span> <span class="nb">len</span><span class="p">(</span><span class="n">x_test_plot</span><span class="p">)</span>
    <span class="p">)</span>

<span class="c1"># --------------------------------------------------</span>
<span class="c1"># h-step-ahead R^2</span>
<span class="c1"># --------------------------------------------------</span>
<span class="n">errors</span> <span class="o">=</span> <span class="n">x_test_plot</span> <span class="o">-</span> <span class="n">x_test_hat_plot</span>
