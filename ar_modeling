            <span class="n">story</span><span class="o">.</span><span class="n">append</span><span class="p">(</span><span class="n">Paragraph</span><span class="p">(</span><span class="s2">"5. Inference for AR Coefficients"</span><span class="p">,</span> <span class="n">styles</span><span class="p">[</span><span class="s2">"Heading1"</span><span class="p">]))</span>
            <span class="n">story</span><span class="o">.</span><span class="n">append</span><span class="p">(</span><span class="n">Paragraph</span><span class="p">(</span>
