<div class=" highlight hl-ipython3"><pre><span></span><span class="kn">import</span> <span class="nn">matplotlib.pyplot</span> <span class="k">as</span> <span class="nn">plt</span>
<span class="kn">import</span> <span class="nn">numpy</span> <span class="k">as</span> <span class="nn">np</span>
<span class="kn">import</span> <span class="nn">math</span>

<span class="c1"># --------------------------------------------------</span>
<span class="c1"># True free-running recursive forecast</span>
<span class="c1"># --------------------------------------------------</span>
<span class="c1"># Seed once using the last LAG_ORDER values from the training set.</span>
<span class="c1"># Then forecast through the entire test set by feeding predictions back into the model.</span>
<span class="c1"># No true test values are used after initialization.</span>

<span class="n">x_train_flat</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">asarray</span><span class="p">(</span><span class="n">x_train</span><span class="p">)</span><span class="o">.</span><span class="n">ravel</span><span class="p">()</span>
<span class="n">x_test_flat</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">asarray</span><span class="p">(</span><span class="n">x_test</span><span class="p">)</span><span class="o">.</span><span class="n">ravel</span><span class="p">()</span>
<span class="n">a_hat_flat</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">asarray</span><span class="p">(</span><span class="n">a_hat</span><span class="p">)</span><span class="o">.</span><span class="n">ravel</span><span class="p">()</span>

<span class="n">history</span> <span class="o">=</span> <span class="nb">list</span><span class="p">(</span><span class="n">x_train_flat</span><span class="p">[</span><span class="o">-</span><span class="n">LAG_ORDER</span><span class="p">:])</span>
<span class="n">x_test_hat_free</span> <span class="o">=</span> <span class="p">[]</span>

<span class="k">for</span> <span class="n">t</span> <span class="ow">in</span> <span class="nb">range</span><span class="p">(</span><span class="nb">len</span><span class="p">(</span><span class="n">x_test_flat</span><span class="p">)):</span>
    <span class="n">lag_values</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">array</span><span class="p">([</span>
        <span class="n">history</span><span class="p">[</span><span class="o">-</span><span class="mi">1</span> <span class="o">-</span> <span class="n">i</span><span class="p">]</span>
        <span class="k">for</span> <span class="n">i</span> <span class="ow">in</span> <span class="nb">range</span><span class="p">(</span><span class="n">LAG_ORDER</span><span class="p">)</span>
    <span class="p">],</span> <span class="n">dtype</span><span class="o">=</span><span class="nb">float</span><span class="p">)</span><span class="o">.</span><span class="n">ravel</span><span class="p">()</span>
    <span class="n">lag_vector</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">concatenate</span><span class="p">(([</span><span class="mf">1.0</span><span class="p">],</span> <span class="n">lag_values</span><span class="p">))</span>

    <span class="n">next_pred</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">dot</span><span class="p">(</span><span class="n">lag_vector</span><span class="p">,</span> <span class="n">a_hat_flat</span><span class="p">)</span>
    <span class="n">x_test_hat_free</span><span class="o">.</span><span class="n">append</span><span class="p">(</span><span class="n">next_pred</span><span class="p">)</span>

    <span class="c1"># Crucial: feed the prediction back in, not the true test value</span>
    <span class="n">history</span><span class="o">.</span><span class="n">append</span><span class="p">(</span><span class="n">next_pred</span><span class="p">)</span>

<span class="n">x_test_hat_free</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">asarray</span><span class="p">(</span><span class="n">x_test_hat_free</span><span class="p">)</span>

<span class="c1"># Flatten for plotting safety</span>
<span class="n">x_test_plot</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">asarray</span><span class="p">(</span><span class="n">x_test_flat</span><span class="p">)</span><span class="o">.</span><span class="n">ravel</span><span class="p">()</span>
<span class="n">x_test_hat_plot</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">asarray</span><span class="p">(</span><span class="n">x_test_hat_free</span><span class="p">)</span><span class="o">.</span><span class="n">ravel</span><span class="p">()</span>

<span class="c1"># --------------------------------------------------</span>
<span class="c1"># Time axis alignment</span>
<span class="c1"># --------------------------------------------------</span>
<span class="n">split_idx</span> <span class="o">=</span> <span class="n">math</span><span class="o">.</span><span class="n">floor</span><span class="p">(</span><span class="n">TRAIN_RATIO</span> <span class="o">*</span> <span class="nb">len</span><span class="p">(</span><span class="n">x</span><span class="p">))</span>

<span class="k">try</span><span class="p">:</span>
    <span class="n">time_axis_full</span> <span class="o">=</span> <span class="n">x_df</span><span class="o">.</span><span class="n">index</span>
    <span class="n">time_axis_test</span> <span class="o">=</span> <span class="n">time_axis_full</span><span class="p">[</span><span class="n">split_idx</span> <span class="p">:</span> <span class="n">split_idx</span> <span class="o">+</span> <span class="nb">len</span><span class="p">(</span><span class="n">x_test_plot</span><span class="p">)]</span>
<span class="k">except</span><span class="p">:</span>
    <span class="n">time_axis_full</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">arange</span><span class="p">(</span><span class="nb">len</span><span class="p">(</span><span class="n">x</span><span class="p">))</span>
    <span class="n">time_axis_test</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">arange</span><span class="p">(</span>
        <span class="n">split_idx</span><span class="p">,</span>
        <span class="n">split_idx</span> <span class="o">+</span> <span class="nb">len</span><span class="p">(</span><span class="n">x_test_plot</span><span class="p">)</span>
    <span class="p">)</span>

<span class="c1"># --------------------------------------------------</span>
<span class="c1"># Free-running recursive R^2</span>
<span class="c1"># --------------------------------------------------</span>
<span class="n">errors</span> <span class="o">=</span> <span class="n">x_test_plot</span> <span class="o">-</span> <span class="n">x_test_hat_plot</span>
<span class="n">centered_x_test</span> <span class="o">=</span> <span class="n">x_test_plot</span> <span class="o">-</span> <span class="n">np</span><span class="o">.</span><span class="n">mean</span><span class="p">(</span><span class="n">x_test_plot</span><span class="p">)</span>

<span class="n">RSS</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">dot</span><span class="p">(</span><span class="n">errors</span><span class="p">,</span> <span class="n">errors</span><span class="p">)</span>
<span class="n">TSS</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">dot</span><span class="p">(</span><span class="n">centered_x_test</span><span class="p">,</span> <span class="n">centered_x_test</span><span class="p">)</span>

<span class="n">R_squared_free</span> <span class="o">=</span> <span class="mi">1</span> <span class="o">-</span> <span class="n">RSS</span> <span class="o">/</span> <span class="n">TSS</span>

<span class="nb">print</span><span class="p">(</span><span class="sa">f</span><span class="s2">"Free-running recursive forecast R^2: </span><span class="si">{</span><span class="n">R_squared_free</span><span class="si">}</span><span class="s2">"</span><span class="p">)</span>

<span class="c1"># --------------------------------------------------</span>
<span class="c1"># 1) Actual vs free-running recursive predictions</span>
<span class="c1"># --------------------------------------------------</span>
<span class="n">plt</span><span class="o">.</span><span class="n">figure</span><span class="p">(</span><span class="n">figsize</span><span class="o">=</span><span class="p">(</span><span class="mi">14</span><span class="p">,</span> <span class="mi">5</span><span class="p">))</span>
<span class="n">plt</span><span class="o">.</span><span class="n">plot</span><span class="p">(</span><span class="n">time_axis_test</span><span class="p">,</span> <span class="n">x_test_plot</span><span class="p">,</span> <span class="n">label</span><span class="o">=</span><span class="s2">"Actual test values"</span><span class="p">)</span>
<span class="n">plt</span><span class="o">.</span><span class="n">plot</span><span class="p">(</span><span class="n">time_axis_test</span><span class="p">,</span> <span class="n">x_test_hat_plot</span><span class="p">,</span> <span class="n">label</span><span class="o">=</span><span class="s2">"Free-running recursive forecast"</span><span class="p">)</span>
<span class="n">plt</span><span class="o">.</span><span class="n">title</span><span class="p">(</span>
    <span class="sa">f</span><span class="s2">"AR(</span><span class="si">{</span><span class="n">LAG_ORDER</span><span class="si">}</span><span class="s2">) Free-Running Recursive Forecast "</span>
    <span class="sa">f</span><span class="s2">"(R² = </span><span class="si">{</span><span class="n">R_squared_free</span><span class="si">:</span><span class="s2">.4f</span><span class="si">}</span><span class="s2">)"</span>
<span class="p">)</span>
<span class="n">plt</span><span class="o">.</span><span class="n">xlabel</span><span class="p">(</span><span class="s2">"Time"</span><span class="p">)</span>
<span class="n">plt</span><span class="o">.</span><span class="n">ylabel</span><span class="p">(</span><span class="s2">"Value"</span><span class="p">)</span>
<span class="n">plt</span><span class="o">.</span><span class="n">legend</span><span class="p">()</span>
<span class="n">plt</span><span class="o">.</span><span class="n">tight_layout</span><span class="p">()</span>
<span class="n">plt</span><span class="o">.</span><span class="n">show</span><span class="p">()</span>

<span class="c1"># --------------------------------------------------</span>
<span class="c1"># 2) Zoomed-in view on the last 200 test points</span>
<span class="c1"># --------------------------------------------------</span>
<span class="n">k</span> <span class="o">=</span> <span class="nb">min</span><span class="p">(</span><span class="mi">200</span><span class="p">,</span> <span class="nb">len</span><span class="p">(</span><span class="n">x_test_plot</span><span class="p">))</span>

<span class="n">plt</span><span class="o">.</span><span class="n">figure</span><span class="p">(</span><span class="n">figsize</span><span class="o">=</span><span class="p">(</span><span class="mi">14</span><span class="p">,</span> <span class="mi">5</span><span class="p">))</span>
<span class="n">plt</span><span class="o">.</span><span class="n">plot</span><span class="p">(</span><span class="n">time_axis_test</span><span class="p">[</span><span class="o">-</span><span class="n">k</span><span class="p">:],</span> <span class="n">x_test_plot</span><span class="p">[</span><span class="o">-</span><span class="n">k</span><span class="p">:],</span> <span class="n">label</span><span class="o">=</span><span class="s2">"Actual test values"</span><span class="p">)</span>
<span class="n">plt</span><span class="o">.</span><span class="n">plot</span><span class="p">(</span><span class="n">time_axis_test</span><span class="p">[</span><span class="o">-</span><span class="n">k</span><span class="p">:],</span> <span class="n">x_test_hat_plot</span><span class="p">[</span><span class="o">-</span><span class="n">k</span><span class="p">:],</span> <span class="n">label</span><span class="o">=</span><span class="s2">"Free-running recursive forecast"</span><span class="p">)</span>
<span class="n">plt</span><span class="o">.</span><span class="n">title</span><span class="p">(</span>
    <span class="sa">f</span><span class="s2">"AR(</span><span class="si">{</span><span class="n">LAG_ORDER</span><span class="si">}</span><span class="s2">) Free-Running Recursive Forecast Last </span><span class="si">{</span><span class="n">k</span><span class="si">}</span><span class="s2"> Points "</span>
    <span class="sa">f</span><span class="s2">"(R² = </span><span class="si">{</span><span class="n">R_squared_free</span><span class="si">:</span><span class="s2">.4f</span><span class="si">}</span><span class="s2">)"</span>
<span class="p">)</span>
<span class="n">plt</span><span class="o">.</span><span class="n">xlabel</span><span class="p">(</span><span class="s2">"Time"</span><span class="p">)</span>
<span class="n">plt</span><span class="o">.</span><span class="n">ylabel</span><span class="p">(</span><span class="s2">"Value"</span><span class="p">)</span>
<span class="n">plt</span><span class="o">.</span><span class="n">legend</span><span class="p">()</span>
<span class="n">plt</span><span class="o">.</span><span class="n">tight_layout</span><span class="p">()</span>
<span class="n">plt</span><span class="o">.</span><span class="n">show</span><span class="p">()</span>

<span class="c1"># --------------------------------------------------</span>
<span class="c1"># 3) Error over time</span>
<span class="c1"># --------------------------------------------------</span>
<span class="n">plt</span><span class="o">.</span><span class="n">figure</span><span class="p">(</span><span class="n">figsize</span><span class="o">=</span><span class="p">(</span><span class="mi">14</span><span class="p">,</span> <span class="mi">4</span><span class="p">))</span>
<span class="n">plt</span><span class="o">.</span><span class="n">plot</span><span class="p">(</span><span class="n">time_axis_test</span><span class="p">,</span> <span class="n">errors</span><span class="p">)</span>
<span class="n">plt</span><span class="o">.</span><span class="n">title</span><span class="p">(</span>
    <span class="sa">f</span><span class="s2">"Free-Running Recursive Forecast Error Over Time "</span>
    <span class="sa">f</span><span class="s2">"(R² = </span><span class="si">{</span><span class="n">R_squared_free</span><span class="si">:</span><span class="s2">.4f</span><span class="si">}</span><span class="s2">)"</span>
<span class="p">)</span>
<span class="n">plt</span><span class="o">.</span><span class="n">xlabel</span><span class="p">(</span><span class="s2">"Time"</span><span class="p">)</span>
<span class="n">plt</span><span class="o">.</span><span class="n">ylabel</span><span class="p">(</span><span class="s2">"Actual - Predicted"</span><span class="p">)</span>
<span class="n">plt</span><span class="o">.</span><span class="n">tight_layout</span><span class="p">()</span>
<span class="n">plt</span><span class="o">.</span><span class="n">show</span><span class="p">()</span>

<span class="c1"># --------------------------------------------------</span>
<span class="c1"># 4) Predicted vs actual scatter</span>
<span class="c1"># --------------------------------------------------</span>
<span class="n">plt</span><span class="o">.</span><span class="n">figure</span><span class="p">(</span><span class="n">figsize</span><span class="o">=</span><span class="p">(</span><span class="mi">6</span><span class="p">,</span> <span class="mi">6</span><span class="p">))</span>
<span class="n">plt</span><span class="o">.</span><span class="n">scatter</span><span class="p">(</span><span class="n">x_test_plot</span><span class="p">,</span> <span class="n">x_test_hat_plot</span><span class="p">,</span> <span class="n">s</span><span class="o">=</span><span class="mi">10</span><span class="p">,</span> <span class="n">alpha</span><span class="o">=</span><span class="mf">0.5</span><span class="p">)</span>

<span class="n">mn</span> <span class="o">=</span> <span class="nb">min</span><span class="p">(</span><span class="n">np</span><span class="o">.</span><span class="n">min</span><span class="p">(</span><span class="n">x_test_plot</span><span class="p">),</span> <span class="n">np</span><span class="o">.</span><span class="n">min</span><span class="p">(</span><span class="n">x_test_hat_plot</span><span class="p">))</span>
<span class="n">mx</span> <span class="o">=</span> <span class="nb">max</span><span class="p">(</span><span class="n">np</span><span class="o">.</span><span class="n">max</span><span class="p">(</span><span class="n">x_test_plot</span><span class="p">),</span> <span class="n">np</span><span class="o">.</span><span class="n">max</span><span class="p">(</span><span class="n">x_test_hat_plot</span><span class="p">))</span>

<span class="n">plt</span><span class="o">.</span><span class="n">plot</span><span class="p">([</span><span class="n">mn</span><span class="p">,</span> <span class="n">mx</span><span class="p">],</span> <span class="p">[</span><span class="n">mn</span><span class="p">,</span> <span class="n">mx</span><span class="p">],</span> <span class="n">linestyle</span><span class="o">=</span><span class="s2">"--"</span><span class="p">)</span>
<span class="n">plt</span><span class="o">.</span><span class="n">title</span><span class="p">(</span>
    <span class="sa">f</span><span class="s2">"Predicted vs Actual: Free-Running Recursive "</span>
